POSTGRES_DB=platformdb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5435
REDIS_PORT=6380

# Shared secret proving requests transited gateway-service (see PlatformAuthGatewayFilterFactory
# in the gateway-service repo). Must be identical here and in gateway-service's
# PLATFORM_GATEWAY_SHARED_SECRET. Rotate away from the placeholder in any real deployment.
PLATFORM_GATEWAY_SHARED_SECRET=CHANGE_ME_INSECURE_DEFAULT_SECRET_ROTATE_IN_PROD
